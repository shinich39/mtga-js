{
  "name": "mtga-js",
  "version": "1.0.0",
  "description": "Make Textarea Garbage Again",
  "keywords": [
    "typescript"
  ],
  "license": "MIT",
  "author": "shinich39 <shinich39@gmail.com>",
  "type": "module",
  "main": "./dist/mtga.min.mjs",
  "module": "./dist/mtga.min.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/mtga.min.mjs",
      "require": "./dist/mtga.min.cjs"
    }
  },
  "scripts": {
    "test": "tsx --test \"**/*.test.{js,jsx,ts,tsx}\"",
    "test:b": "playwright test",
    "dev": "nodemon --config nodemon.config.json",
    "build": "node esbuild.config.js && tsc",
    "check": "biome check . --write",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.14.0",
    "esbuild": "^0.25.2",
    "husky": "^9.1.7",
    "nodemon": "^3.1.11",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}